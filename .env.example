# MongoDB 连接字符串（替换为你的 MongoDB Atlas 地址）
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/boss-resource?retryWrites=true&w=majority

# JWT 密钥（生产环境请使用复杂随机字符串）
JWT_SECRET=boss-resource-jwt-secret-change-in-production

# 服务端口
PORT=3001

# 前端地址（CORS）
FRONTEND_URL=http://localhost:5173
